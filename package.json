{
  "name": "markit",
  "productName": "Markit",
  "version": "0.0.3",
  "main": "./dist/main/app.js",
  "scripts": {
    "build": "npm run build:main && npm run build:renderer && npm run copy:assets",
    "build:dev": "npm run build:main:dev && npm run build:renderer:dev && npm run copy:assets",
    "build:prod": "npm run build:main:prod && npm run build:renderer:prod && npm run copy:assets",
    "build:main": "tsc",
    "build:main:dev": "tsc --sourceMap --inlineSources",
    "build:main:prod": "tsc --sourceMap false --removeComments --inlineSourceMap false",
    "build:renderer": "esbuild markit/renderer/renderer.ts --bundle --outfile=dist/markit/renderer/renderer.js --platform=browser --target=es2020 --format=iife --external:electron",
    "build:renderer:dev": "esbuild markit/renderer/renderer.ts --bundle --outfile=dist/markit/renderer/renderer.js --platform=browser --target=es2020 --format=iife --sourcemap=inline --external:electron",
    "build:renderer:prod": "esbuild markit/renderer/renderer.ts --bundle --outfile=dist/markit/renderer/renderer.js --platform=browser --target=es2020 --format=iife --minify --external:electron",
    "copy:assets": "mkdir -p dist/markit && cp markit/index.html dist/markit/index.html && cp -R markit/assets dist/markit/assets",
    "watch:main": "tsc --watch",
    "watch:renderer": "tsc -p tsconfig.renderer.json --watch",
    "start": "npm run build:dev && electron dist/markit/main/app.js",
    "start:prod": "npm run build:prod && electron dist/markit/main/app.js",
    "format": "prettier --write markit/",
    "lint": "eslint markit/**/*.ts",
    "lint:fix": "eslint markit/**/*.ts --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rm -rf build dist",
    "package": "npx electron-packager .  Markit --platform=linux,darwin --arch=x64 --icon markit/assets/images/markit.icns --out build/",
    "dmg": "electron-installer-dmg build/markit-darwin-x64/Markit.app --icon markit/assets/images/markit.icns --out build/installer Markit",
    "deb": "electron-installer-debian --src build/markit-linux-x64/ --platform linux --arch amd64 --icon markit/assets/images/markit.icns --dest build/installer",
    "installer": "npm run clean && npm run build && npm run package && npm run dmg && npm run deb"
  },
  "author": "Jianli Zhang",
  "license": "MIT",
  "keywords": [
    "Markdown",
    "Markdown Editor"
  ],
  "dependencies": {
    "@octokit/rest": "^22.0.0",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.2",
    "marked": "^16.4.0",
    "marked-base-url": "^1.1.7",
    "marked-code-preview": "^1.3.7",
    "marked-emoji": "^2.0.1",
    "marked-highlight": "^2.2.2"
  },
  "description": "Markdown Editor",
  "devDependencies": {
    "@electron/packager": "^18.4.4",
    "@eslint/js": "^9.37.0",
    "@jest/globals": "^30.2.0",
    "@types/electron": "^1.4.38",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^28.0.0",
    "@types/marked": "^5.0.2",
    "@types/node": "^24.7.1",
    "electron": "^38.2.2",
    "electron-installer-debian": "^3.2.0",
    "electron-installer-dmg": "^5.0.1",
    "electron-reload": "^2.0.0-alpha.1",
    "esbuild": "^0.25.10",
    "eslint": "^9.37.0",
    "eslint-plugin-node": "^11.1.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-mock-extended": "^4.0.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.4",
    "typescript": "^5.9.3"
  }
}
