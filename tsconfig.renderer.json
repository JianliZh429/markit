{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "outDir": "./dist/renderer",
    "rootDir": "./markit/renderer",
    "types": ["node"],
    "moduleResolution": "node",
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictFunctionTypes": true,
    "sourceMap": true,
    "inlineSources": true
  },
  "include": ["markit/renderer/**/*"],
  "exclude": ["markit/renderer/renderer.js", "markit/renderer/menu.js"]
}
